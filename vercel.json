{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "pompesFunèbresmaroc.com"
        }
      ],
      "destination": "https://www.pompesFunèbresmaroc.com/$1",
      "permanent": true
    },
    {
      "source": "/assistance-immediate",
      "destination": "/assistance",
      "permanent": true
    },
    {
      "source": "/services/pompes-Funèbres-musulmanes",
      "destination": "/service/pompes-Funèbres-musulmanes",
      "permanent": true
    },
    {
      "source": "/services/pompes-Funèbres-non-musulmanes",
      "destination": "/service/pompes-Funèbres-non-musulmanes",
      "permanent": true
    },
    {
      "source": "/services/fleurs",
      "destination": "/service/fleurs",
      "permanent": true
    },
    {
      "source": "/services/nettoyage-et-fleurissement",
      "destination": "/service/nettoyage-fleurissement",
      "permanent": true
    },
    {
      "source": "/services/marbrerie-musulmane",
      "destination": "/produits/marbrerie-musulmane",
      "permanent": true
    },
    {
      "source": "/services/marbrerie-non-musulmane",
      "destination": "/produits/marbrerie-non-musulmane",
      "permanent": true
    },
    {
      "source": "/agences/:slug",
      "destination": "/villes/:slug",
      "permanent": true
    },
    {
      "source": "/pompes-Funèbres/musulmanes",
      "destination": "/service/pompes-Funèbres-musulmanes",
      "permanent": true
    },
    {
      "source": "/pompes-Funèbres/non-musulmanes",
      "destination": "/service/pompes-Funèbres-non-musulmanes",
      "permanent": true
    },
    {
      "source": "/produits/fleurs",
      "destination": "/service/fleurs",
      "permanent": true
    },
    {
      "source": "/produits/nettoyage-fleurissement",
      "destination": "/service/nettoyage-fleurissement",
      "permanent": true
    },
    {
      "source": "/service/marbrerie-musulmane",
      "destination": "/produits/marbrerie-musulmane",
      "permanent": true
    },
    {
      "source": "/service/marbrerie-non-musulmane",
      "destination": "/produits/marbrerie-non-musulmane",
      "permanent": true
    },
    {
      "source": "/service/services-entreprises",
      "destination": "/services-entreprises",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
